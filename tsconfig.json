{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noEmitOnError": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@apptypes/*": ["types/*"],
      "@schemas/*": ["schemas/*"],
      "@config/*": ["config/*"],
      "@agents/*": ["agents/*"]
    }
  },
  "include": ["src/**/*", "types/**/*", "schemas/**/*", "config/**/*", "agents/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
