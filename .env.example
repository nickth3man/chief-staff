# =====================================================================
# chief-staff — environment configuration
# Copy to `.env` and fill in. All values shown are working defaults
# taken from config/paths.ts and config/workflows.ts.
# =====================================================================

# ---------------------------------------------------------------------
# REQUIRED
# Runtime stops at the first LLM call if this is missing.
# Consumed by: src/_shared/llm.ts (OpenAI SDK with base_url override)
# ---------------------------------------------------------------------

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# OpenRouter chat-completions base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------
# OPTIONAL — model selection
# Mirrors config/workflows.ts. Any OpenRouter model id works.
# ---------------------------------------------------------------------

# Chief / orchestrator default fallback model
# Consumed by: config/workflows.ts (MODELS.chief, MODELS.orchestrator)
# TODO: confirm via OpenRouter /models endpoint
CHIEF_DEFAULT_MODEL=inclusionai/ring-2.6-1t

# Workflow 1 (briefing-prep): main LLM
# Consumed by: src/workflows/briefing-prep/steps.ts
# TODO: confirm via OpenRouter /models endpoint
WF1_LLM_MODEL=inclusionai/ring-2.6-1t

# Workflow 1: text-to-speech model
# Consumed by: src/_shared/tts.ts
WF1_TTS_MODEL=openai/gpt-4o-mini-tts

# Workflow 2 (curation): LLM used per chunk
# Consumed by: src/workflows/curation/steps.ts
# TODO: confirm via OpenRouter /models endpoint
WF2_LLM_MODEL=inclusionai/ring-2.6-1t

# Workflow 3 (weekly-digest): LLM
# Consumed by: src/workflows/weekly-digest/steps.ts
# TODO: confirm via OpenRouter /models endpoint
WF3_LLM_MODEL=inclusionai/ring-2.6-1t

# Workflow 4 (meeting-followup): schema-extraction model
# Consumed by: src/workflows/meeting-followup/prompts.ts (extractMetadata)
# TODO: confirm via OpenRouter /models endpoint
WF4_SCHEMA_MODEL=inclusionai/ring-2.6-1t

# Workflow 4: notes-polish LLM
# Consumed by: src/workflows/meeting-followup/prompts.ts (polishNotes)
# TODO: confirm via OpenRouter /models endpoint
WF4_LLM_MODEL=inclusionai/ring-2.6-1t

# Workflow 4: follow-up email draft LLM
# Consumed by: src/workflows/meeting-followup/prompts.ts (draftEmail)
# TODO: confirm via OpenRouter /models endpoint
WF4_EMAIL_MODEL=inclusionai/ring-2.6-1t

# Orchestrator routing model
# Consumed by: src/orchestrator/orchestrator.ts
# TODO: confirm via OpenRouter /models endpoint
ORCHESTRATOR_MODEL=inclusionai/ring-2.6-1t

# ---------------------------------------------------------------------
# OPTIONAL — text-to-speech
# ---------------------------------------------------------------------

# TTS voice id (alloy | echo | fable | onyx | nova | shimmer for OpenAI tts)
# Consumed by: src/_shared/tts.ts
TTS_VOICE=alloy

# TTS output container (mp3 | wav | opus)
# Consumed by: src/_shared/tts.ts
TTS_FORMAT=mp3

# ---------------------------------------------------------------------
# OPTIONAL — workflow knobs
# Mirrors config/workflows.ts (WORKFLOW_KNOBS).
# ---------------------------------------------------------------------

# Workflow 2: items per LLM chunk
# Consumed by: src/workflows/curation/_shared/chunker.ts
WF2_CHUNK_SIZE=10

# Workflow 2: require human confirmation before promoting a tier
# Consumed by: src/workflows/curation/steps.ts
WF2_TIER_CONFIRM=true

# Workflow 2: max items to fetch per RSS feed
# Consumed by: src/workflows/curation/run.ts
WF2_FETCH_CAP_PER_FEED=5

# Workflow 2: only consider items newer than this many hours
# Consumed by: src/workflows/curation/_shared/chunker.ts (filterRecent)
WF2_TIME_WINDOW_HOURS=24

# Workflow 3: max items to fetch per RSS feed
# Consumed by: src/workflows/weekly-digest/run.ts
WF3_FETCH_CAP_PER_FEED=5

# ---------------------------------------------------------------------
# OPTIONAL — filesystem paths (relative to project root)
# Mirrors config/paths.ts. Override if you keep assets elsewhere.
# ---------------------------------------------------------------------

# Consultant-X client files (per-account dossiers)
# Consumed by: config/paths.ts (paths.assets.consultantX)
ASSETS_CONSULTANT_DIR=assets/consultant_x

# Meeting transcripts staged for WF4
# Consumed by: config/paths.ts (paths.assets.transcripts)
ASSETS_TRANSCRIPTS_DIR=assets/transcripts

# Polished meeting notes written by WF4
# Consumed by: config/paths.ts (paths.assets.meetingDocuments)
ASSETS_MEETING_DOCS_DIR=assets/meeting-documents

# Generated artifacts (briefings, audio, drafts, run logs, CSVs)
# Consumed by: config/paths.ts (paths.outbox.*)
OUTBOX_DIR=outbox

# Run logs (per-workflow .jsonl)
# Consumed by: config/paths.ts (paths.logs)
LOGS_DIR=logs

# Cost + token usage CSVs
# Consumed by: config/paths.ts (paths.metrics.*)
METRICS_DIR=metrics

# Sandbox inputs for local workflow runs
# Consumed by: config/paths.ts (paths.testRecords.*)
TEST_RECORDS_DIR=test_records

# ---------------------------------------------------------------------
# OPTIONAL — sender identity
# Resolves the "hardcoded sender" issue flagged in WF4.
# Consumed by: config/workflows.ts (SENDER); available to any step that
# wants to sign an outbound artifact.
# ---------------------------------------------------------------------

SENDER_NAME=Chief of Staff
SENDER_EMAIL=chief-of-staff@acmecorp.com

# ---------------------------------------------------------------------
# OPTIONAL — web server
# Consumed by: config/workflows.ts (SERVER); src/server/index.ts.
# ---------------------------------------------------------------------

PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------
# OPTIONAL — human-in-the-loop
# Consumed by: config/workflows.ts (HITL); src/_shared/hitl.ts.
# HITL_MODE options: cli | web
#   - cli: prompt() in the terminal (default)
#   - web: serve prompts via /prompt and /prompt/answer
# ---------------------------------------------------------------------

HITL_MODE=cli
REQUIRE_APPROVAL=false

# ---------------------------------------------------------------------
# OPTIONAL — logging
# Consumed by: config/workflows.ts (LOG_LEVEL).
# Allowed: trace | debug | info | warn | error | fatal
# ---------------------------------------------------------------------

LOG_LEVEL=info
